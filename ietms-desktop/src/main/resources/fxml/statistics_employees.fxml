<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.CheckComboBox?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21.0.7"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mayak.ietms.ui.analytics.controller.EmployeeStatisticsController"
            styleClass="scroll-minimal"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <VBox spacing="10"
          alignment="TOP_CENTER"
          style="-fx-padding: 0 20 10 20">

        <HBox spacing="10" alignment="CENTER">
        <padding><Insets top="10" bottom="10"/></padding>

            <!-- Date range -->
            <VBox spacing="10" alignment="CENTER">
                <Label fx:id="departmentFullNameLabel"  style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="departmentComboBox" promptText="select department"
                          visible="false" managed="false"
                          prefWidth="150"/>
                <DatePicker fx:id="startDatePicker" maxWidth="150" styleClass="date-picker"
                            promptText="dd.mm.yyyy"/>
                <DatePicker fx:id="endDatePicker" maxWidth="150" styleClass="date-picker"
                            promptText="dd.mm.yyyy"/>
                <CheckComboBox fx:id="usersComboBox" prefWidth="150"/>
                <Button text="report" maxHeight="Infinity" onAction="#handleFormReport"
                        prefWidth="150" styleClass="report-outline"/>
            </VBox>

        </HBox>

        <Separator HBox.hgrow="ALWAYS"/>

        <HBox fx:id="placeholderContainer" alignment="CENTER" VBox.vgrow="ALWAYS">
            <Label text="report hasn't been formed yet..." style="-fx-opacity: 0.5;"/>
        </HBox>

        <VBox fx:id="reportContainer"/>

    </VBox>
</ScrollPane>