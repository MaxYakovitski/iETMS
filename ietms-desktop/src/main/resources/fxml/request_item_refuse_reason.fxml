<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21.0.7"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mayak.iet.ui.workspace.request.item.RefuseReasonController"
      spacing="20" alignment="CENTER"
      stylesheets="@../css/styles.css"
      styleClass="app-root">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

        <ComboBox fx:id="reasonChoiceBox" promptText="select the reason" prefWidth="200"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="submitButton"
                    text="submit"
                    onAction="#handleSubmit" focusTraversable="false"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="cancelButton"
                    text="cancel"
                    onAction="#handleCancel" focusTraversable="false"/>

        </HBox>

</VBox>