<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.ProgressBar?>
<VBox xmlns="http://javafx.com/javafx/21.0.7"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mayak.ietms.ui.analytics.controller.ReportController"
      alignment="CENTER" spacing="10" prefWidth="360"
      stylesheets="@../css/styles.css"
      styleClass="app-root">

    <padding>
        <Insets top="20" bottom="20"/>
    </padding>

    <VBox fx:id="formContainer" alignment="CENTER" spacing="10">
        <ComboBox fx:id="reportChoiceBox" promptText="report type" prefWidth="150.0" styleClass="combo-box"/>
        <DatePicker fx:id="startDatePicker" maxWidth="150" styleClass="date-picker" promptText="dd.mm.yyyy"/>
        <DatePicker fx:id="endDatePicker" maxWidth="150" styleClass="date-picker" promptText="dd.mm.yyyy"/>
        <Button fx:id="downloadButton" mnemonicParsing="false" text="download" styleClass="report-outline" onAction="#handleDownload"/>
    </VBox>

    <ProgressBar fx:id="progressBar" prefWidth="180" managed="false" visible="false" progress="0" styleClass="update-progress"/>
</VBox>