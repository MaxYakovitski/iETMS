<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.Region?>
<?import org.controlsfx.control.CheckComboBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21.0.7"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mayak.ietms.ui.workspace.request.filter.RequestFilterController"
      alignment="CENTER" spacing="15"
      stylesheets="@../css/styles.css"
      styleClass="app-root">

    <padding>
        <Insets top="20" left="30" right="30" bottom="20"/>
    </padding>

            <GridPane fx:id="grid" hgap="10" vgap="15" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints prefWidth="75" halignment="LEFT"/>
                    <ColumnConstraints prefWidth="200"/>
                </columnConstraints>

                <!-- Status -->
                <CheckComboBox fx:id="statusComboBox" prefWidth="150" focusTraversable="false"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <!-- Request type: spot / contract -->
                <Label fx:id="requestLabel" text="request:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <HBox fx:id="requestTypeRow" spacing="30" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <RadioButton fx:id="spotRadioButton" text="spot" toggleGroup="$requestTypeGroup"
                                 focusTraversable="false"/>
                    <RadioButton fx:id="contractRadioButton" text="contract" toggleGroup="$requestTypeGroup"
                                 focusTraversable="false"/>
                </HBox>

                <!-- From / To -->
                <Label text="from:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <HBox spacing="5">
                        <TextField fx:id="fromIsoField" maxWidth="50" promptText="iso" styleClass="price-field"
                                   focusTraversable="false"/>
                        <TextField fx:id="fromZipField" maxWidth="95" promptText="zip" styleClass="price-field"
                                   focusTraversable="false"/>
                    </HBox>
                    <TextField fx:id="fromPlaceField" maxWidth="150" promptText="place"
                               styleClass="price-field" focusTraversable="false"/>
                </VBox>

                <Label text="to:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <VBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                    <HBox spacing="5">
                        <TextField fx:id="toIsoField" maxWidth="50" promptText="iso" styleClass="price-field"
                                   focusTraversable="false"/>
                        <TextField fx:id="toZipField" maxWidth="95" promptText="zip" styleClass="price-field"
                                   focusTraversable="false"/>
                    </HBox>
                    <TextField fx:id="toPlaceField" maxWidth="150" promptText="place" styleClass="price-field"
                               focusTraversable="false"/>
                </VBox>

                <Label text="company:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="companyField" promptText="name"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                           styleClass="price-field" focusTraversable="false" maxWidth="150"/>

                <!-- Type of date-->
                <ComboBox fx:id="typeOfDateComboBox" promptText="type of date"
                          GridPane.rowIndex="5" GridPane.columnIndex="1" focusTraversable="false" maxWidth="150"/>

                <!-- Period: start / end -->
                <Label text="start date:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <DatePicker fx:id="startDatePicker"
                            GridPane.rowIndex="6" GridPane.columnIndex="1"
                            styleClass="date-picker" focusTraversable="false" maxWidth="150"/>

                <Label text="end date:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <DatePicker fx:id="endDatePicker"
                            GridPane.rowIndex="7" GridPane.columnIndex="1"
                            styleClass="date-picker" focusTraversable="false" maxWidth="150"/>

                <!-- Shipment type FTL / LTL -->
                <Label text="type:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <HBox spacing="55" GridPane.rowIndex="8" GridPane.columnIndex="1">
                    <RadioButton fx:id="ftlRadioButton" text="FTL" toggleGroup="$shipmentTypeGroup"
                                 focusTraversable="false"/>
                    <RadioButton fx:id="ltlRadioButton" text="LTL" toggleGroup="$shipmentTypeGroup"
                                 focusTraversable="false"/>
                </HBox>

                <!-- Transport -->
                <CheckComboBox fx:id="transportComboBox" prefWidth="150" focusTraversable="false"
                               GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                <!-- ADR -->
                <ComboBox fx:id="adrComboBox" promptText="dangerous" GridPane.rowIndex="10" GridPane.columnIndex="1"
                          focusTraversable="false"/>

                <!-- Weight / LDM -->
                <Label text="weight, KG:" GridPane.rowIndex="11" GridPane.columnIndex="0"/>
                <HBox GridPane.rowIndex="11" GridPane.columnIndex="1" maxWidth="150">
                    <TextField fx:id="weightFrom" promptText="from" focusTraversable="false"
                               style="-fx-background-color: #ffffff; -fx-background-radius: 5 0 0 5;
                               -fx-border-color: #c8c8c8; -fx-border-radius: 5 0 0 5; -fx-border-width: 1 0 1 1;"/>
                    <TextField fx:id="weightTo" promptText="to" focusTraversable="false"
                               style="-fx-background-color: #ffffff; -fx-background-radius: 0 5 5 0;
                               -fx-border-color: #c8c8c8; -fx-border-radius: 0 5 5 0;"/>
                </HBox>

                <Label text="LDM:" GridPane.rowIndex="12" GridPane.columnIndex="0"/>
                <HBox GridPane.rowIndex="12" GridPane.columnIndex="1" maxWidth="150">
                    <TextField fx:id="ldmFromField" promptText="from" focusTraversable="false"
                               style="-fx-background-color: #ffffff; -fx-background-radius: 5 0 0 5;
                               -fx-border-color: #c8c8c8; -fx-border-radius: 5 0 0 5; -fx-border-width: 1 0 1 1;"/>
                    <TextField fx:id="ldmToField" promptText="to"
                               GridPane.rowIndex="12" GridPane.columnIndex="1"
                               focusTraversable="false"
                               style="-fx-background-color: #ffffff; -fx-background-radius: 0 5 5 0;
                               -fx-border-color: #c8c8c8; -fx-border-radius: 0 5 5 0;"/>
                </HBox>

                <!-- users -->
                <CheckComboBox fx:id="authorsMultiSelectComboBox" prefWidth="150" focusTraversable="false"
                               GridPane.rowIndex="13" GridPane.columnIndex="1"/>

                <CheckComboBox fx:id="competitorsMultiSelectComboBox" prefWidth="150" focusTraversable="false"
                               GridPane.rowIndex="14" GridPane.columnIndex="1"/>

                <CheckComboBox fx:id="dispatcherMultiSelectComboBox" prefWidth="150" focusTraversable="false"
                               GridPane.rowIndex="15" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox alignment="CENTER">
                <Button text="reset filters" prefWidth="235" mnemonicParsing="false" onAction="#handleReset"
                        focusTraversable="false"
                        styleClass="reset-outline"/>
            </HBox>

            <HBox>
                <Button text="submit" mnemonicParsing="false" onAction="#handleSubmit" focusTraversable="false"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="cancel" mnemonicParsing="false" onAction="#handleCancel" focusTraversable="false"/>
            </HBox>

</VBox>