<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>

<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Spinner?>
<HBox xmlns="http://javafx.com/javafx/21.0.7"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mayak.iet.ui.workspace.planner.controller.PlannerController"
      spacing="15"
      stylesheets="@../css/styles.css"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets top="25" bottom="25" left="25" right="25"/>
    </padding>

    <VBox alignment="TOP_CENTER"
          prefWidth="400"
          maxWidth="400"
          spacing="10">

        <Label fx:id="yearLabel" style="-fx-text-fill: #2196f3; -fx-font-size: 20"/>

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="leftButton" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" opacity="0.65"
                    onAction="#handleLeft"
                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                        <Image url="@/icons/left-chevron.png"/>
                    </ImageView>
                </graphic>
            </Button>

            <Label fx:id="monthLabel"/>

            <Button fx:id="rightButton" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" opacity="0.65"
                    onAction="#handleRight"
                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                        <Image url="@/icons/right-chevron.png"/>
                    </ImageView>
                </graphic>
               </Button>
           </HBox>

        <StackPane fx:id="calendarContainer"/>

        <StackPane fx:id="detailsStack" visible="false" managed="false">
            <VBox fx:id="shipmentDetailsContainer"
                  alignment="CENTER" spacing="10"
                  visible="false" managed="false"
            style="-fx-background-color: #f9f9f9; -fx-background-radius: 5">
                <padding>
                    <Insets top="10" bottom="10" right="10" left="10"/>
                </padding>
                <VBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Shipment:" />
                        <Label fx:id="shipmentNumber"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label text="dispatched to:"/>
                        <Label fx:id="dispatcher"/>
                    </HBox>
                </VBox>
                <Button fx:id="cancelButton" text="cancel" prefWidth="100"  onAction="#handleCancel" styleClass="reset-outline"/>
                <VBox fx:id="timelineContainer"/>
            </VBox>

            <VBox fx:id="transportDetailsContainer" alignment="CENTER" spacing="10"
                  style="-fx-background-color: #f9f9f9; -fx-background-radius: 5">
                <padding>
                    <Insets top="10" bottom="10" right="10" left="10"/>
                </padding>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Shipment:" />
                    <Label fx:id="shipmentNumberTransport"/>
                </HBox>
                <TextField fx:id="carrierField" promptText="add carrier..." prefWidth="Infinity" styleClass="price-field"/>
                <HBox alignment="CENTER" spacing="5">
                    <TextField fx:id="licensePlateField" prefWidth="150" promptText="add license plate..." styleClass="price-field"/>
                    <TextField fx:id="transportOrder" HBox.hgrow="ALWAYS" promptText="add transport order..." styleClass="price-field"/>
                </HBox>
                <HBox alignment="CENTER" spacing="5">
                    <ComboBox fx:id="shipmentStatusComboBox" promptText="change status" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="28" styleClass="white-combo"/>
                    <DatePicker fx:id="dateAndTime" prefWidth="125" disable="true"/>
                    <Spinner fx:id="timeSpinner" prefWidth="100" disable="true"/>
                </HBox>
                <TextArea fx:id="commentsTextArea" promptText="add comments..." styleClass="price-field" />
                <HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="submitButton" text="submit" prefWidth="100"  styleClass="submit-outline" onAction="#submitShipmentUpdate"/>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>

    <Separator orientation="VERTICAL"/>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <HBox fx:id="buttonsContainer" spacing="10" alignment="CENTER" StackPane.alignment="TOP_CENTER">
            <Button fx:id="myShipments" text="My shipments" prefWidth="100" styleClass="tab" onAction="#onMyShipmentsHandle"/>
            <Button fx:id="myTransports" text="My transports" prefWidth="100" styleClass="tab" onAction="#onMyTransportsHandle"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS">
            <VBox fx:id="myShipmentsContainer" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" StackPane.alignment="CENTER"
                  style="-fx-background-color: #f9f9f9; -fx-background-radius: 5" >
                <padding><Insets top="20"/></padding>
                <ListView fx:id="shipmentsListView"  VBox.vgrow="ALWAYS" styleClass="app-list-view"/>
            </VBox>

            <VBox fx:id="myTransportsContainer" alignment="TOP_CENTER" spacing="20" StackPane.alignment="CENTER">

                <VBox fx:id="toLoadContainer" alignment="TOP_CENTER" spacing="10" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f9f9f9; -fx-background-radius: 5">
                    <padding><Insets top="10"/></padding>
                    <Label text="to load:" style="-fx-text-fill: #2196f3; -fx-font-size: 16;"/>
                    <ListView fx:id="toLoadListView"  VBox.vgrow="ALWAYS" styleClass="app-list-view"/>
            <!-- controls -->
                </VBox>

        <!-- TO DROP -->
                <VBox fx:id="toDropContainer" alignment="TOP_CENTER" spacing="10" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f9f9f9; -fx-background-radius: 5">
                    <padding><Insets top="10"/></padding>
                    <Label text="to drop:" style="-fx-text-fill: #2196f3; -fx-font-size: 16;"/>
                    <ListView fx:id="toDropListView"  VBox.vgrow="ALWAYS" styleClass="app-list-view"/>
            <!-- controls -->
                </VBox>
            </VBox>

            <Label fx:id="emptyMessageLabel"
                   text="Oops! No shipments found..."
                   visible="false" managed="false"
                   style="-fx-opacity: 0.5;"/>

        </StackPane>

    </VBox>

</HBox>