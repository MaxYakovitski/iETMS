<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21.0.7"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mayak.iet.ui.about.AboutController"
            prefWidth="360" alignment="CENTER"
            stylesheets="@../css/styles.css"
            styleClass="anchor-pane">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <Label text="iETMS" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <Separator>
            <padding>
                <Insets top="10" bottom="10"/>
            </padding>
        </Separator>

    <Label fx:id="versionLabel" text="Version:"/>
    <Label text="© 2026 by Maxim Yakovitski"/>


</VBox>